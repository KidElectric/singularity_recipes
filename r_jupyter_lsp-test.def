BootStrap: docker 
From: ubuntu:latest

%help
R jupyter env named r_env with working R autocompletion

%runscript
    if [ $# -ne 1 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate r_env
    Rscript $1

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    conda activate r_env
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y g++ gcc unzip gzip \
        ca-certificates wget libfontconfig1-dev \
        build-essential libcurl4-openssl-dev libssl-dev libxml2-dev
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda update conda
    conda config --set solver libmamba
    conda create -n r_env -c conda-forge python=3 -y
    conda activate r_env
    conda install -c conda-forge nodejs 'jupyterlab>=4.0.10,<5.0.0a0' r-base r-irkernel jupyter-lsp-r -y 
  
    # Set up IR Kernel for use w/ jupyter
    R -e "IRkernel::installspec(name = 'r_env' , displayname = 'R4 seurat (Sing)')" 

    # R installs
    # R -e "install.packages('languageserver', repos='http://lib.stat.cmu.edu/R/CRAN/')"
    R -e "install.packages('devtools', repos='http://lib.stat.cmu.edu/R/CRAN/')"
    R -e "install.packages('ggplot2', repos='http://lib.stat.cmu.edu/R/CRAN/')" 
    R -e "install.packages('dplyr', repos='http://lib.stat.cmu.edu/R/CRAN/')" 

    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
