BootStrap: docker
From: ubuntu:latest

%help
Base with miniconda, jupyterlab and vpython in env named py38

%runscript
    if [ $# -ne 3 ]; then
        echo "Please provide an input python script (.py), input path (str), and an output file path (str)."
        exit 1
    fi
    echo "USING":$CONDA_PY
    $CONDA_PY $1 $2 $3

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    CONDA_PY=$CONDA_DIR/envs/py38/bin/python3.8
    export CONDA_DIR CONDA_SRC CONDA_PY

%post
    apt-get update -qq
    apt-get install -y -q --no-install-recommends \
	 wget ca-certificates
         
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n py38 python=3.8 -y
    conda activate py38
    conda install -c conda-forge jupyterlab-vpython matplotlib
    conda install -c anaconda ipykernel
    conda install -c vpython vpython
    python -m ipykernel install --name py38_sing --display-name "Singularity (py38_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* 
    rm ~/miniconda.sh
