BootStrap: docker 
From: ubuntu:latest

%help
Base with pathml and pyvips in env named py38.

%runscript
    echo "Installing and making image with pathml and pyvips conda environment."

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=/opt/conda/etc/profile.d/conda.sh
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -y openslide-tools g++ gcc \
	libblas-dev liblapack-dev python3-opencv \
	unzip gzip 
    . /opt/conda/etc/profile.d/conda.sh
    conda activate py38
    conda install -c conda-forge numpy openjdk==8.0.152 jupyterlab pyvips -y 
    conda install ipykernel pandas matplotlib -y
    pip install pathml
    python -m ipykernel install --name py38_sing --display-name "Singularity (py38_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
