BootStrap: docker 
From: ubuntu:latest

%help
R jupyter env named r_lme4_test

%runscript
    if [ $# -ne 1 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate r_lme4_test
    Rscript $1

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    conda activate r_lme4_test
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y g++ gcc unzip gzip \
        ca-certificates wget libfontconfig1-dev \
        libharfbuzz-dev libfribidi-dev libfreetype6-dev \
        libpng-dev libtiff5-dev libjpeg-dev \
        libbz2-dev liblzma-dev libcurl4-openssl-dev \
	libunwind-dev libxrender-dev 
    wget https://repo.anaconda.com/miniconda/Miniconda3-4.7.12.1-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $APPTAINER_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda update conda
    conda create -n r_lme4_test python=3.8 -y
    conda activate r_lme4_test
    conda install -c conda-forge r-essentials jupyterlab -y

    # R -e "install.packages('lme4', repos='http://lib.stat.cmu.edu/R/CRAN/')"
    #R -e "install.packages('IRkernel', repos='http://lib.stat.cmu.edu/R/CRAN/')" 

    # Set up IR Kernel for use w/ jupyter
   # R -e "IRkernel::installspec(name = 'r_lme4_test' , displayname = 'R4.2.0 with lme4 (Sing)')" 
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
