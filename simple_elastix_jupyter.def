BootStrap: localimage 
From: /home/brian/singularity/images/simple_elastix.simg

%help
Base with simpleelastix and env named py38 with goodies

%runscript
    echo "Installing and making simple elastix from local image with conda already in it."

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=/opt/conda/etc/profile.d/conda.sh
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install python3-opencv
    . /opt/conda/etc/profile.d/conda.sh
    conda activate py38
    conda install scipy ipykernel numpy pandas matplotlib \
    	 scikit-learn scikit-image -y
    conda install -c conda-forge jupyterlab -y
    pip install opencv-python-headless
    python -m ipykernel install --name py38_sing --display-name "Python (py38_sing)"
    conda clean --all
