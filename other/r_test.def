BootStrap: docker 
From: ubuntu:latest

%help
R jupyter env named r_seurat

%runscript
    if [ $# -ne 1 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate r_seurat
    Rscript $1

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    conda activate r_seurat
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y g++ gcc unzip gzip \
	ca-certificates wget libfontconfig1-dev \
	libharfbuzz-dev libfribidi-dev libfreetype6-dev	\
	libpng-dev libtiff5-dev libjpeg-dev \
	libbz2-dev liblzma-dev libcurl4-openssl-dev
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n r_seurat -c conda-forge -c bioconda r-seurat=4* -y
    conda activate r_seurat
    conda install -c conda-forge jupyterlab r-devtools -y 
    R -e "install.packages('devtools', repos='http://lib.stat.cmu.edu/R/CRAN/')"
    
    # devtools / github installs:
    R -e "devtools::install_github('jokergoo/ComplexHeatmap')"

    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
