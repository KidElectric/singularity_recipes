BootStrap: docker 
From: ubuntu:latest

%help
VectraTools package 07-12-2024 in vectral_tools conda envinroment.

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate vectra_tools
    python $1 $2

%files
    /home/brian/repos/VectraTools /opt/VectraTools
%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y g++ gcc unzip gzip ca-certificates wget
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n vectra_tools python=3.11 -y
    conda activate vectra_tools
    conda install tensorflow
    conda install bs4 lxml matplotlib openpyxl pydantic pygraphviz pytest seaborn scikit-learn shapely xmltodict toolz umap-learn -y
    conda install -c conda-forge pandera stardist -y
    pip install infotools roifile more_itertools
    conda install -c anaconda ipykernel
    python -m ipykernel install --name vectra_tools --display-name "Singularity (vtools_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
