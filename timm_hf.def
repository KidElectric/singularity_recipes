BootStrap: docker 
From: ubuntu:latest

%help
timm, pytorch lightning, timm and huggingface installed in env named py310

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate py310
    python $1 $2

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    conda activate py310
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y g++ gcc \
	libblas-dev libpng-dev libjpeg-dev zlib1g-dev liblapack-dev \
	python3-opencv unzip gzip ca-certificates wget 
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n py310 python=3.10 -y
    conda activate py310
    # conda install pytorch torchvision torchaudio pytorch-cuda=11.7 -c pytorch -c nvidia
    #conda install pytorch==1.12.1 torchvision==0.13.1 torchaudio==0.12.1 cudatoolkit=11.6 -c pytorch -c conda-forge
    # conda install -c conda-forge platformdirs #pytorch=1.12*
    pip install timm
    pip install huggingface_hub
    #    conda install lightning -c conda-forge -y
    #pip install timm
    #conda install -c fastchan fastai -y
    conda install -c conda-forge nodejs jupyterlab jupyter-resource-usage jupyterlab-nvdashboard jupyterlab-spreadsheet-editor ipympl -y
    pip install openpyxl
    conda install -c anaconda ipykernel seaborn -y
    python -m ipykernel install --name py310_sing --display-name "Singularity (py310_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
