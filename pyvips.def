BootStrap: docker 
From: ubuntu:latest

%help
Base with pyvips in env named py38.

%runscript
    echo "Installing and making image with pyvips conda environment."

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=/opt/conda/etc/profile.d/conda.sh
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y \
        unzip gzip ca-certificates wget
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n py38 python=3.8 -y
    conda activate py38
    conda install -c conda-forge pyvips -y 
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
