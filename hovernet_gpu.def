Bootstrap: docker
From: ubuntu:latest # div1121/hovernet-gpu:latest

%help
Hovernet base in env named hovernet

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate hovernet
    python $1 $2
%files
   
%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install --no-install-recommends -q -y gcc g++ ca-certificates wget git
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    git clone https://github.com/vqdang/hover_net.git /opt/hovernet
    #    ls /opt/hovernet
    cd /opt/hovernet	
    #conda env create -f /opt/hovernet/environment.yml
    conda env create -f environment.yml
    conda activate hovernet
    #conda install -c conda-forge jupyterlab -y #numpy=1.19.5
    conda install pytorch-gpu torchvision cudatoolkit=11.3 -c pytorch
    #conda install -c anaconda ipykernel
    #python -m ipykernel install --name hovernet_sing --display-name "Singularity (hovernet_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh

