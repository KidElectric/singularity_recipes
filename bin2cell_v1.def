BootStrap: docker 
From: ubuntu:latest

%help
bin2cell using tensorflow StarDist for Visium HD base in env named py310

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate py310
    python $1 $2

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y openslide-tools g++ gcc \
	libblas-dev liblapack-dev python3-opencv \
	unzip gzip ca-certificates wget texlive-xetex
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n py310 python=3.10 -y
    conda activate py310
    conda install -c conda-forge nodejs jupyterlab=4.2.5 jupyterlab-lsp scanpy python-igraph umap-learn\
	numpy openjdk==8.0.152 jupyter-resource-usage jupyterlab-spreadsheet-editor ipympl \
	geojson python-lsp-server tensorflow -y

    pip install scanpy
    pip install bin2cell
    pip install openpyxl
    pip install geojsoncontour
    pip install cv2geojson
    conda install -c anaconda ipykernel
    python -m ipykernel install --name py310_sing --display-name "Singularity (py310_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
