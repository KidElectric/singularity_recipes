Bootstrap: docker
From: ubuntu:latest

%runscript
    /qupath/QuPath-v0.5.1-Linux/QuPath/bin/QuPath $1

%post
    mkdir /qupath
    cd /qupath
    apt-get update
    apt-get install -y wget xz-utils default-jre
    wget https://github.com/qupath/qupath/releases/download/v0.5.1/QuPath-v0.5.1-Linux.tar.xz
    tar -xvf ./QuPath-v0.5.1-Linux.tar.xz
    ls
    chmod u+x ./QuPath-v0.5.1-Linux/QuPath/bin/QuPath
    rm ./QuPath-v0.5.1-Linux.tar.xz
