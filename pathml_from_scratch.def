BootStrap: docker 
From: ubuntu:latest

%help
Pathml base in env named py38

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    source activate py38
    python $1 $2

%environment
    CONDA_DIR=/opt/conda
    CONDA_SRC=$CONDA_DIR/etc/profile.d/conda.sh
    . $CONDA_SRC
    conda activate py38
    export CONDA_DIR CONDA_SRC

%post
    apt-get update -qq
    apt-get install -q -y openslide-tools g++ gcc \
	libblas-dev liblapack-dev python3-opencv \
	unzip gzip ca-certificates wget 
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    echo 'export PATH=/opt/conda/bin:/opt/conda/condabin:$PATH' >> $SINGULARITY_ENVIRONMENT
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n py38 python=3.8 -y
    conda activate py38
    conda install -c conda-forge numpy openjdk==8.0.152 jupyterlab -y #numpy=1.19.5
    conda install pytorch torchvision torchaudio cudatoolkit=11.3 -c pytorch
    pip install pathml
    pip install openpyxl
    conda install -c anaconda ipykernel
    python -m ipykernel install --name py38_sing --display-name "Singularity (py38_sing)"
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
