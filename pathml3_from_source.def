BootStrap: docker 
From: ubuntu:latest

%help
Pathml base in env named pathml

%runscript
    if [ $# -ne 2 ]; then
    	echo "Please provide an input python script and an output file path."
	exit 1
    fi
    python $1 $2

%environment
    export JAVA_HOME=/opt/conda/envs/pathml
    export PATH=/opt/conda/envs/pathml/bin:$PATH
%files
    ./setup.py /opt/pathml/
    ./README.md /opt/pathml/
    ./requirements/ /opt/pathml/
    ./examples/ /opt/pathml/
    ./tests/ /opt/pathml/
    ./pathml/ /opt/pathml
    ./docker/entrypoint.sh /opt/pathml/

%post
    ls /opt/pathml/requirements
    apt-get update -qq
    apt-get install -q -y openslide-tools g++ gcc \
	libblas-dev libpixman-1-0 liblapack-dev \
        ffmpeg libsm6 libxext6 ca-certificates wget
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh --ca-directory=/usr/ssl/certs -O ~/miniconda.sh
    bash ~/miniconda.sh -b -p /opt/conda
    . /opt/conda/etc/profile.d/conda.sh
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r
    conda env create -f /opt/pathml/requirements/environment_singularity.yml
    conda activate pathml
    conda clean --all
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
    rm ~/miniconda.sh
